# ═══════════════════════════════════════════════════════════════════════
#  Research Intelligence Agent — Environment Variables
#  Copy to .env and fill in values.
#  NEVER commit .env to source control.
#  In production: all secrets come from Azure Key Vault via Managed Identity.
# ═══════════════════════════════════════════════════════════════════════

# ─── Azure OpenAI (via Managed Identity — NO key needed in production) ──────
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
# For LOCAL DEV only (in production this is Managed Identity):
AZURE_OPENAI_API_KEY=

# ─── Azure (Managed Identity + Key Vault) ───────────────────────────────────
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_KEY_VAULT_URL=https://<your-kv>.vault.azure.net/
# Local dev only (in production use Managed Identity):
AZURE_CLIENT_SECRET=

# ─── PostgreSQL (LangGraph Checkpointer) ────────────────────────────────────
# Local dev: docker-compose postgres. Production: Azure Flexible Server.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=research_agent
POSTGRES_USER=research_user
POSTGRES_PASSWORD=local_dev_only_change_in_prod
# Full connection string (auto-built from above if left blank):
# POSTGRES_DSN=postgresql://user:pass@host:5432/db

# ─── Redis (Semantic Cache + Rate Limiter backend) ───────────────────────────
REDIS_URL=redis://localhost:6379/0
# Production: Azure Cache for Redis (TLS)
# REDIS_URL=rediss://:<access-key>@<name>.redis.cache.windows.net:6380/0

# ─── Agent Tools ────────────────────────────────────────────────────────────
# Tavily: https://app.tavily.com — free tier: 1,000 searches/month
# In production: stored in Key Vault as secret "tavily-api-key"
TAVILY_API_KEY=tvly-...

# ─── LangFuse (self-hosted LLM observability — data stays in your infra) ────
# Local dev: docker-compose langfuse. Production: Container App.
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...

# ─── Azure Application Insights (infra observability via OpenTelemetry) ─────
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...

# ─── Azure AI Content Safety ─────────────────────────────────────────────────
AZURE_CONTENT_SAFETY_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com/
# In production: Managed Identity. Local dev only:
AZURE_CONTENT_SAFETY_KEY=

# ─── Entra ID Auth (feature flag — default off for local dev) ────────────────
ENABLE_AUTH=false
AZURE_AUTH_TENANT_ID=
AZURE_AUTH_CLIENT_ID=
# Backend API audience (api://<client-id>)
AZURE_AUTH_AUDIENCE=

# ─── Application Settings ────────────────────────────────────────────────────
APP_ENV=development                   # development | staging | production
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001
# Per-user rate limit (requests per minute)
RATE_LIMIT_PER_MINUTE=20
# Max LLM tokens per research request
MAX_TOKENS_PER_REQUEST=10000
# Redis cache TTL for identical queries (seconds)
CACHE_TTL_SECONDS=3600
