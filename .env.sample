# Research Intelligence Agent — copy to .env and fill in values.
# NEVER commit .env. In production, secrets come from Azure Key Vault.

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-5-mini
AZURE_OPENAI_API_KEY=          # local dev only — leave empty in production (Managed Identity)

# Azure Identity & Key Vault
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=           # local dev only
AZURE_KEY_VAULT_URL=https://<your-kv>.vault.azure.net/

# PostgreSQL — LangGraph checkpointer (Neon.tech for dev, Azure Flexible Server for prod)
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=research_agent
POSTGRES_USER=research_user
POSTGRES_PASSWORD=

# Redis — rate limiter backend (leave empty to use in-memory, not suitable for multi-replica)
REDIS_URL=redis://localhost:6379/0

# Tavily — web + news search (free tier: 1,000 searches/month — https://app.tavily.com)
TAVILY_API_KEY=tvly-...

# LangFuse — self-hosted LLM observability (traces stay in your infrastructure)
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...

# Azure Application Insights — infrastructure observability via OpenTelemetry
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...

# Azure AI Content Safety
AZURE_CONTENT_SAFETY_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com/
AZURE_CONTENT_SAFETY_KEY=      # local dev only

# Entra ID Auth — disabled by default for local dev, enable in production
ENABLE_AUTH=false
AZURE_AUTH_TENANT_ID=
AZURE_AUTH_CLIENT_ID=
AZURE_AUTH_AUDIENCE=           # format: api://<client-id>

# Application
APP_ENV=development            # development | staging | production
LOG_LEVEL=INFO
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3001"]   # JSON array required
RATE_LIMIT_PER_MINUTE=20
MAX_TOKENS_PER_REQUEST=10000
CACHE_TTL_SECONDS=3600
